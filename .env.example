APP_NAME="School Management System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://school.example.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=school_management
DB_USERNAME=schooluser
DB_PASSWORD=schoolpass123
DB_ROOT_PASSWORD=rootpass123

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=redispass123
REDIS_PORT=6379

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis
CACHE_PREFIX=school_
# Queue Configuration - Options: sync, database, redis, beanstalkd, sqs
# - sync: Immediate execution (no queue worker needed, good for development)
# - database: Uses database table (requires migration: php artisan queue:table && php artisan migrate)
# - redis: Uses Redis (requires Redis setup, recommended for production)
# - beanstalkd: Uses Beanstalkd queue service
# - sqs: Uses AWS SQS (requires AWS credentials)
QUEUE_CONNECTION=redis

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=school_app
REVERB_APP_KEY=school_key_123
REVERB_APP_SECRET=school_secret_123
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http

# Pusher Configuration (if using Pusher broadcaster)
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=ap1
PUSHER_BASE_PATH=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https

# Authentication Configuration
AUTH_GUARD=web
AUTH_PASSWORD_BROKER=users
AUTH_MODEL=App\Models\User
AUTH_PASSWORD_RESET_TOKEN_TABLE=password_reset_tokens
AUTH_PASSWORD_TIMEOUT=10800

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

FILESYSTEM_DISK=public

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@school.example.com"
MAIL_FROM_NAME="${APP_NAME}"

MIDTRANS_IS_PRODUCTION=true
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_SNAP_ENDPOINT=https://app.midtrans.com/snap/v1/transactions
MIDTRANS_CHARGE_ENDPOINT=https://api.midtrans.com/v2/charge
MIDTRANS_CANCEL_ENDPOINT="https://api.midtrans.com/v2/{order_id}/cancel"
MIDTRANS_REFUND_ENDPOINT="https://api.midtrans.com/v2/{order_id}/refund"
MIDTRANS_WEBHOOK_URL=

WHATSAPP_API_URL=https://graph.facebook.com/v24.0
WHATSAPP_API_VERSION=v24.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=verify_token_123
WHATSAPP_BUSINESS_ID=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Sentry Error Tracking & Monitoring
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=1.0.0
SENTRY_SEND_DEFAULT_PII=false
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=0.0

# Sentry Breadcrumbs Configuration
SENTRY_BREADCRUMBS_LOGS_ENABLED=true
SENTRY_BREADCRUMBS_CACHE_ENABLED=true
SENTRY_BREADCRUMBS_LIVEWIRE_ENABLED=true
SENTRY_BREADCRUMBS_SQL_QUERIES_ENABLED=true
SENTRY_BREADCRUMBS_SQL_BINDINGS_ENABLED=false
SENTRY_BREADCRUMBS_QUEUE_INFO_ENABLED=true
SENTRY_BREADCRUMBS_COMMAND_JOBS_ENABLED=true
SENTRY_BREADCRUMBS_HTTP_CLIENT_REQUESTS_ENABLED=true
SENTRY_BREADCRUMBS_NOTIFICATIONS_ENABLED=true

# Sentry Tracing Configuration
SENTRY_TRACE_QUEUE_ENABLED=true
SENTRY_TRACE_QUEUE_JOBS_ENABLED=true
SENTRY_TRACE_SQL_QUERIES_ENABLED=true
SENTRY_TRACE_SQL_BINDINGS_ENABLED=false
SENTRY_TRACE_SQL_ORIGIN_ENABLED=true
SENTRY_TRACE_SQL_ORIGIN_THRESHOLD_MS=100
SENTRY_TRACE_VIEWS_ENABLED=true
SENTRY_TRACE_LIVEWIRE_ENABLED=true
SENTRY_TRACE_HTTP_CLIENT_REQUESTS_ENABLED=true
SENTRY_TRACE_CACHE_ENABLED=true
SENTRY_TRACE_REDIS_COMMANDS=false
SENTRY_TRACE_REDIS_ORIGIN_ENABLED=true
SENTRY_TRACE_NOTIFICATIONS_ENABLED=true
SENTRY_TRACE_MISSING_ROUTES_ENABLED=false
SENTRY_TRACE_CONTINUE_AFTER_RESPONSE=true
SENTRY_TRACE_DEFAULT_INTEGRATIONS_ENABLED=true

# AWS S3 Configuration (required for export file storage on S3; leave empty to use local disk)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-3
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

SCHOOL_NAME=ProductSchool
SCHOOL_PHONE=
SCHOOL_ADDRESS="Jl. Pendidikan No. 1, Makassar"
SCHOOL_EMAIL=info@school.example.com
SCHOOL_PRINCIPAL="Kepala Sekolah"

ATTENDANCE_RADIUS_METERS=100
EMPLOYEE_ATTENDANCE_RADIUS=500
EMPLOYEE_ATTENDANCE_LOCATION_LATITUDE=-6.2088
EMPLOYEE_ATTENDANCE_LOCATION_LONGITUDE=106.8456
ENABLE_GPS_ATTENDANCE=true

AUTO_CHECKOUT_TIME="17:00"
LEAVE_REQUEST_AUTO_APPROVAL_DAYS=3
PAYMENT_DUE_DAYS=7
GRADE_POSTING_NOTIFICATION=true

ENABLE_BULK_IMPORT=true
ENABLE_PAYMENT_GATEWAY=true
ENABLE_NOTIFICATIONS=true
ENABLE_BROADCASTING=true
ENABLE_AUDIT_LOGS=true

API_RATE_LIMIT_REQUESTS=60
API_RATE_LIMIT_MINUTES=1

APP_DEBUG_MODE=false
LOG_SQL_QUERIES=false
SKIP_PERMISSION_CHECK=false

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
