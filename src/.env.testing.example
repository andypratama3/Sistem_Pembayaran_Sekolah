# Testing Environment Configuration
# Copy this file to .env.testing and update values as needed
# DO NOT commit .env.testing to version control

APP_NAME="ProductSchool"
APP_ENV=testing
APP_KEY=base64:yqFSd/HfLo+jb+YTyxAr72SWcWQ2BSAPSLU/AkiaOJU=
APP_DEBUG=true
APP_URL=http://localhost

# Database (SQLite in-memory for tests)
DB_CONNECTION=sqlite
DB_DATABASE=:memory:

# Cache & Session
CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync

# Mail
MAIL_MAILER=array

# Broadcasting
BROADCAST_DRIVER=log

# Disable monitoring in tests
PULSE_ENABLED=false
TELESCOPE_ENABLED=false
SENTRY_LARAVEL_DSN=null
SENTRY_DSN=null
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_PROFILES_SAMPLE_RATE=0
